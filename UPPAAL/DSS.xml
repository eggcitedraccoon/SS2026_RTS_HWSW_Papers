	<system>// Process instantiations
		P0 = PeriodicTask(0);
		P1 = PeriodicTask(1);
		D2 = DSS(2);
		Src = Source();
		Tkr = Ticker();
		Cpu = CPU();

		// List processes to be composed into a system.
		system P0, P1, D2, Src, Tkr, Cpu;
	</system>
	<queries>
		<query>
			<formula>A[] not deadlock</formula>
			<comment>The system is deadlock-free.</comment>
		</query>
		<query>
			<formula>A[] forall (i : int[0, 1]) (rel_d[i] &gt;= -1)</formula>
			<comment>Periodic tasks always meet their deadlines.</comment>
		</query>
		<query>
			<formula>A[] (rem_req_c &gt; 0 imply rel_d[DSS_ID] &gt;= -1)</formula>
			<comment>NEW: the aperiodic request being serviced by the DSS also meets its deadline. Previously rel_d[DSS_ID] was never checked, which is how the burst-bookkeeping bug stayed hidden.</comment>
		</query>
		<query>
			<formula>E&lt;&gt; D2.Active</formula>
			<comment>The DSS can be active (servicing requests).</comment>
			<result outcome="success" type="quality" timestamp="2026-06-20 18:39:54 +0200">
			</result>
		</query>
		<query>
			<formula>A[] budget &gt;= 0 &amp;&amp; budget &lt;= MAX_BUDGET</formula>
			<comment>DSS budget remains within valid bounds.</comment>
		</query>
		<query>
			<formula>A[] (Tkr.Wait imply (D2.Active imply cpu_task == DSS_ID))</formula>
			<comment>DSS is Active only when assigned to CPU (in stable state).</comment>
		</query>
		<query>
			<formula>A[] (Tkr.Wait imply (P0.Active imply cpu_task == 0))</formula>
			<comment>Task P0 is Active only when assigned to CPU.</comment>
		</query>
		<query>
			<formula>A[] (Tkr.Wait imply (P1.Active imply cpu_task == 1))</formula>
			<comment>Task P1 is Active only when assigned to CPU.</comment>
		</query>
		<query>
			<formula>A[] (Tkr.Wait imply (Cpu.Busy imply cpu_task != -1))</formula>
			<comment>CPU Busy implies a task is assigned.</comment>
		</query>
		<query>
			<formula>A[] (Tkr.Wait imply (Cpu.Idle imply cpu_task == -1))</formula>
			<comment>CPU Idle implies no task is assigned.</comment>
		</query>
	</queries>
