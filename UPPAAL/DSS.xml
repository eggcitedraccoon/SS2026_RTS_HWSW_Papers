<nta>
	<declaration>// Global constants
		const int N = 3;         // 2 Periodic Tasks + 1 DSS
		const int DSS_ID = 2;    // ID of the DSS task

		// Channels
		broadcast chan tick;     // Discrete time step
		broadcast chan request;  // Aperiodic request arrival
		broadcast chan reschedule; // Force CPU and tasks to update their states

		// Common System State
		int cpu_task = -1;       // Currently executing task ID
		int budget = 10;         // Current DSS budget
		const int MAX_BUDGET = 10;
		int rem_req_c = 0;       // Remaining capacity for current DSS request

		// Task Parameters: {T_i, C_i}
		int T[N] = {10, 20, 40}; // Periods
		int C[N] = {3, 4, 10};   // Capacity (Execution time)

		// Dynamic Task State (Relative)
		int rel_d[N] = {10, 20, 40};        // Relative deadlines
		bool ready[N] = {true, true, false}; // Task is ready to execute
		int rem_c[N] = {3, 4, 0};            // Remaining computation time
		int p[N] = {0, 0, 0};                // Phase/timer for periodic tasks

		// Global Functions
		void select_task() {
		int i;
		int best = -1;
		for (i = 0; i &lt; N; i++) {
		bool is_really_ready = false;
		if (i == DSS_ID) {
		if (budget &gt; 0 &amp;&amp; rem_req_c &gt; 0) is_really_ready = true;
		} else {
		if (ready[i] &amp;&amp; rem_c[i] &gt; 0) is_really_ready = true;
		}
		if (is_really_ready) {
		if (best == -1 || rel_d[i] &lt; rel_d[best]) {
		best = i;
		}
		}
		}
		cpu_task = best;
		}

		void update_periodic(int id) {
		if (cpu_task == id &amp;&amp; rem_c[id] &gt; 0) {
		rem_c[id]--;
		if (rem_c[id] == 0) ready[id] = false;
		}
		if (ready[id] &amp;&amp; rel_d[id] &gt; -10) rel_d[id]--;
		if (p[id] &lt; T[id]) p[id]++;
		if (p[id] == T[id]) {
		p[id] = 0;
		rem_c[id] = C[id];
		rel_d[id] = T[id];
		ready[id] = true;
		}
		}

		// Replenishment Queue for DSS
		const int Q_SIZE = 11;
		int repl_amt[Q_SIZE];
		int repl_t[Q_SIZE];
		int head = 0;
		int tail = 0;
		int repl_count = 0;

		int current_burst_amt = 0;
		int burst_timer = 0;
		bool in_burst = false;

		void update_dss(int id) {
		int i;
		// 1. Progress existing replenishments
		for (i = 0; i &lt; repl_count; i++) {
		int idx = (head + i) % Q_SIZE;
		if (repl_t[idx] &gt; 0) {
		repl_t[idx]--;
		}
		}

		// 2. Check for completed replenishments
		while (repl_count &gt; 0 &amp;&amp; repl_t[head] == 0) {
		budget += repl_amt[head];
		if (budget &gt; MAX_BUDGET) budget = MAX_BUDGET;
		head = (head + 1) % Q_SIZE;
		repl_count--;
		}

		// 3. Handle Consumption and Burst
		if (in_burst) {
		if (cpu_task == id &amp;&amp; budget &gt; 0) {
		budget--;
		rem_req_c--;
		current_burst_amt++;
		}
		if (burst_timer &gt; 0) burst_timer--;

		// FIX (bandwidth preservation): a full T_s has elapsed while the
		// server is still active (e.g. it was preempted, not exhausted).
		// Settle whatever has been consumed so far right now, and open a
		// fresh replenishment window for whatever gets consumed next,
		// instead of letting burst_timer sit at 0 and replenishing the
		// *entire* burst immediately once it eventually ends.
		if (burst_timer == 0 &amp;&amp; rem_req_c &gt; 0 &amp;&amp; budget &gt; 0) {
		if (current_burst_amt &gt; 0) {
		repl_amt[tail] = current_burst_amt;
		repl_t[tail] = 0;
		tail = (tail + 1) % Q_SIZE;
		repl_count++;
		}
		current_burst_amt = 0;
		burst_timer = T[id];
		}

		// End of burst: no more requests OR out of budget
		if (rem_req_c == 0 || budget == 0) {
		if (current_burst_amt &gt; 0) {
		repl_amt[tail] = current_burst_amt;
		repl_t[tail] = burst_timer;
		tail = (tail + 1) % Q_SIZE;
		repl_count++;
		}
		in_burst = false;
		}
		} else {
		// Potential start of burst
		if (rem_req_c &gt; 0 &amp;&amp; budget &gt; 0) {
		in_burst = true;
		burst_timer = T[id];
		current_burst_amt = 0;
		// FIX (deadline integrity): rel_d[id] is intentionally NOT
		// touched here. It is the EDF urgency of the pending request
		// and must only be set on genuine request arrival (see the
		// request? transitions in the DSS template). Resetting it
		// here every time a new burst starts let replenishment
		// bookkeeping silently overwrite real task urgency.

		if (cpu_task == id) {
		budget--;
		rem_req_c--;
		current_burst_amt++;
		}
		if (burst_timer &gt; 0) burst_timer--;

		// Check if burst ended immediately
		if (rem_req_c == 0 || budget == 0) {
		if (current_burst_amt &gt; 0) {
		repl_amt[tail] = current_burst_amt;
		repl_t[tail] = burst_timer;
		tail = (tail + 1) % Q_SIZE;
		repl_count++;
		}
		in_burst = false;
		}
		}
		}

		// 4. Deadline countdown for DSS (driven purely by request arrival;
		// never reset by burst/replenishment bookkeeping above)
		if (rem_req_c &gt; 0 &amp;&amp; rel_d[id] &gt; -10) {
		rel_d[id]--;
		}
		}
	</declaration>
