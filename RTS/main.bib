@article{Spuri1996,
    abstract = {In this paper we present ve new on-line algorithms for servicing soft aperiodic requests in real-time systems, where a set of hard periodic tasks is scheduled using the Earliest Deadline First (EDF) algorithm. All the proposed solutions can achieve full processor utilization and enhance aperiodic responsiveness, still guaranteeing the execution of the periodic tasks. Operation of the algorithms, performance, schedulability analysis, and implementation complexity are discussed and compared with classical alternative s o l u t i o n s , s u c h a s b a c kground and polling service. Extensive simulations show that algorithms with contained run-time overhead present nearly optimal responsiveness. A v aluable contribution of this work is to provide the real-time system designer with a wide range of practical solutions which a l l o w to balance eeciency against implementation complexity.},
    author = {Marco Spuri and Giorgio Buttazzo},
    doi = {10.1007/BF00360340},
    issn = {0922-6443},
    issue = {2},
    journal = {Real-Time Systems},
    month = {3},
    pages = {179-210},
    title = {Scheduling aperiodic tasks in dynamic priority systems},
    volume = {10},
    url = {http://link.springer.com/10.1007/BF00360340},
    year = {1996}
}
@article{Zhang2014,
    abstract = {<p>This paper focus on the dynamic server algorithms, and the servers are used for scheduling soft aperiodic tasks. Many types of servers and their schedulability analysis are reviewed, these properties can be used for constructing hierarchical embedded systems, where the soft aperiodic tasks and the hard real-time tasks can be scheduled in the same system. The aperiodic tasks in the server are not preemptable, and they are executed in a first-come first-served (FCFS) manner. If it is not specified, there is only one server in the system, and rest of the processes in the system are ordinary periodic tasks. The servers could be scheduled by fixed priority or dynamic algorithms.</p>},
    author = {Feng Xiang Zhang},
    doi = {10.4028/www.scientific.net/AMR.945-949.3380},
    isbn = {9783038351221},
    issn = {1662-8985},
    journal = {Advanced Materials Research},
    keywords = {Aperiodic task,Fixed priority,Schedulability analysis,Scheduling,Server algorithms},
    month = {6},
    pages = {3380-3383},
    publisher = {Trans Tech Publications Ltd},
    title = {The Algorithms of Dynamic Servers for Scheduling Aperiodic Real-Time Tasks – A Review},
    volume = {945-949},
    url = {https://www.scientific.net/AMR.945-949.3380},
    year = {2014}
}

